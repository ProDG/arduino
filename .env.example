# DEV defaults — fresh `cp .env.example .env` produces a working dev stack.
# For prod: regenerate ALL passwords/keys/secrets; never reuse these values.

# Postgres
POSTGRES_DB=arduino
POSTGRES_USER=arduino
POSTGRES_PASSWORD=arduino-dev-pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Django / Wagtail
# Generate a SECRET_KEY for your local .env with:
#   python -c 'import secrets; print(secrets.token_urlsafe(64))'
# Never commit a real key to .env.example or any tracked file.
DJANGO_SECRET_KEY=
DJANGO_SETTINGS_MODULE=wagtail_arduino.settings.dev
DJANGO_ALLOWED_HOSTS=arduino.localhost,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://arduino.localhost
WAGTAIL_BASE_URL=http://arduino.localhost

# MinIO
# Wagtail container reaches MinIO via Docker DNS (http://minio:9000).
# Ad-hoc host-side scripts (mc CLI, browser) use http://localhost:9000 + console http://localhost:9001 (dev only).
# DEV-ONLY credentials. Wagtail uses the same root creds as MinIO via DJANGO_AWS_*.
MINIO_ROOT_USER=arduino-dev
MINIO_ROOT_PASSWORD=arduino-dev-pass
DJANGO_AWS_S3_ENDPOINT_URL=http://minio:9000
DJANGO_AWS_STORAGE_BUCKET_NAME=arduino-media
DJANGO_AWS_ACCESS_KEY_ID=arduino-dev
DJANGO_AWS_SECRET_ACCESS_KEY=arduino-dev-pass
