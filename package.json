{
  "name": "arduino-hub",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test arduino-hub --watch=false && ng test core-ui --watch=false",
    "test:watch": "ng test core-ui",
    "lint": "eslint . && stylelint \"src/**/*.scss\" && node scripts/lint-fixtures.mjs",
    "lint:js": "eslint .",
    "lint:scss": "stylelint \"src/**/*.scss\"",
    "lint:verify-rule": "bash -c 'eslint --no-ignore src/__synthetic__/eslint-violation-fixture.ts; if [ $? -ne 0 ]; then echo \"PASS: rule fired on synthetic violation\"; exit 0; else echo \"FAIL: rule did not fire on synthetic violation\"; exit 1; fi'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fonts:subset": "node scripts/fonts/subset.mjs",
    "fonts:metrics": "node scripts/fonts/fontaine-metrics.mjs"
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.9",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.17.19",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "angular-eslint": "^21.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "fontaine": "0.8.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.1.0",
    "stylelint": "^16.10.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.15.0",
    "vitest": "^4.0.8"
  }
}
